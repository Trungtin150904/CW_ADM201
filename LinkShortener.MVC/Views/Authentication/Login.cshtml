@model LinkShortener.MVC.Models.LoginVM
@{
    ViewData["Title"] = "Đăng nhập";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="auth-wrapper d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="auth-card card border-0 shadow-lg p-4" style="width: 100%; max-width: 420px;">

        <div class="text-center mb-4">
            <h2 class="fw-bold mt-2">Sign In</h2>
            <p class="text-muted">Welcome back!</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

        <form asp-controller="Authentication" asp-action="Login"
              asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" class="form-control form-control-lg"
                       placeholder="name@example.com" autocomplete="username" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                <input asp-for="Password" class="form-control form-control-lg"
                       placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4 d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <input class="form-check-input" asp-for="RememberMe" />
                    <label class="form-check-label text-muted" asp-for="RememberMe">Remember me</label>
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                Sign in
            </button>
        </form>

        <hr class="my-4" />

        <p class="text-center text-muted mb-0">
            Don't have an account yet?
            <a asp-controller="Authentication" asp-action="Register"
                   asp-route-returnUrl="@Model.ReturnUrl" class="fw-semibold text-primary">
                Register now
            </a>
        </p>

        @* ===== TK Admin mặc định ===== *@
        @* <div class="text-center mt-3 p-3 bg-light rounded small text-muted">
            <strong>Admin mặc định:</strong><br />
            Email: <code>admin@shorturl.com</code><br />
            Password: <code>Admin@123</code>
        </div> *@
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}