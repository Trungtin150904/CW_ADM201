@model LinkShortener.MVC.Models.RegisterVM
@{
    ViewData["Title"] = "Đăng ký";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card border-0 shadow-lg p-4" style="width: 100%; max-width: 420px;">

        <div class="text-center mb-4">
            <h2 class="fw-bold mt-2">Create an account</h2>
            <p class="text-muted">Register to use the service</p>
        </div>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

        <form asp-controller="Authentication" asp-action="Register"
              asp-route-returnUrl="@Model.ReturnUrl" method="post">

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" class="form-control form-control-lg"
                       placeholder="name@example.com" autocomplete="username" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                <input asp-for="Password" class="form-control form-control-lg" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label fw-semibond">Confirm password</label>
                <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold">
                Sign up
            </button>
        </form>

        <hr class="my-4" />

        <p class="text-center text-muted mb-0">
            Do you already have an account?
            <a asp-controller="Authentication" asp-action="Login" class="fw-semibold text-primary">
                Sign in
            </a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}