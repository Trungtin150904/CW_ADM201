@using LinkShortener.Common.DTOs
@model List<ShortUrlDto>

@{
    ViewData["Title"] = "URL Shortener";
}

<div class="shorturl-wrapper">

    <div class="hero-section text-center py-5 mb-4">
        <h1 class="hero-title">URL Shortener</h1>
        <p class="hero-subtitle">Shorten long links into shorter, more shareable links.</p>

        <form method="post" action="/ShortUrl/Create" class="hero-form mx-auto mt-4">
            <div class="input-group input-group-lg shadow">
                <span class="input-group-text bg-white border-end-0">
                    <i class="bi bi-link-45deg text-primary fs-4"></i>
                </span>
                <input type="text"
                       name="originalUrl"
                       class="form-control border-start-0 ps-0"
                       placeholder="Enter the URL to be shortened (ex: https://example.com)"
                       required />
                <button type="submit" class="btn btn-primary px-4 fw-bold">
                    Shorten
                </button>
            </div>
        </form>
    </div>

    @if (TempData["ShortLink"] != null)
    {
        <div class="alert alert-success alert-dismissible d-flex align-items-center gap-3 shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill fs-4 text-success"></i>
            <div class="flex-grow-1">
                <strong>Successful creation!</strong> <br>
                Your short URL:
                <a href="@TempData["ShortLink"]" target="_blank" class="fw-bold text-success">
                    @TempData["ShortLink"]
                </a>
            </div>
            <button type="button"
                    class="btn btn-sm btn-outline-success"
                    onclick="navigator.clipboard.writeText('@TempData["ShortLink"]'); this.innerText='✅ Copied!'">
                📋 Copy
            </button>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible d-flex align-items-center gap-2 shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-5"></i>
            <div>@TempData["Error"]</div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">📋 List of shortened URLs</h5>
                <span class="badge bg-primary rounded-pill">@Model.Count URLs</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4" style="width:50px">ID</th>
                                <th style="min-width:260px">Original URL</th>
                                <th style="min-width:220px">Short URL</th>
                                <th class="text-center" style="width:80px">Clicks</th>
                                <th style="width:140px">Creation date</th>
                                <th class="text-center" style="width:100px">Operation</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 text-muted">@item.Id</td>
                                    <td>
                                        <a href="@item.OriginalUrl" target="_blank"
                                               class="text-decoration-none text-dark original-url-link"
                                               title="@item.OriginalUrl">
                                            <i class="bi bi-box-arrow-up-right me-1 text-muted small"></i>
                                            @(item.OriginalUrl?.Length > 55
                                                ? item.OriginalUrl.Substring(0, 55) + "..."
                                                : item.OriginalUrl)
                                        </a>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <a href="@item.ShortLink" target="_blank"
                                                   class="text-primary fw-semibold text-decoration-none short-link-text">
                                                @item.ShortLink
                                            </a>
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-2 copy-btn flex-shrink-0"
                                                    data-url="@item.ShortLink"
                                                    title="Copy link">
                                                📋
                                            </button>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill @(item.ClickCount > 0 ? "bg-success" : "bg-secondary")">
                                            @item.ClickCount
                                        </span>
                                    </td>
                                    <td class="text-muted small">
                                        @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </td>
                                    <td class="text-center">
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <form asp-controller="ShortUrl" asp-action="Delete"
                                                  method="post" class="d-inline"
                                                  onsubmit="return confirm('Do you want to remove this URL?')">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                                                    Delete
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="text-muted small">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 text-muted">
            <div style="font-size: 4rem;">🔗</div>
            <h5 class="mt-3">No Short URLs available</h5>
            <p>Enter the URL above to start shortening!</p>
        </div>
    }

</div>

<style>
    .shorturl-wrapper {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .hero-section {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 1.5rem;
        color: white;
        padding: 3rem 2rem !important;
    }

    .hero-title {
        font-size: 2.5rem;
        font-weight: 800;
        letter-spacing: -0.5px;
    }

    .hero-subtitle {
        font-size: 1.1rem;
        opacity: 0.9;
    }

    .hero-form {
        max-width: 700px;
    }

        .hero-form .input-group {
            border-radius: 0.75rem;
            overflow: hidden;
        }

        .hero-form .form-control {
            font-size: 1rem;
            padding: 0.75rem 1rem;
        }

            .hero-form .form-control:focus {
                box-shadow: none;
            }

    .original-url-link:hover {
        color: #0d6efd !important;
    }

    .short-link-text {
        word-break: break-all;
    }

    .copy-btn:active {
        transform: scale(0.95);
    }
</style>

<script>
    document.querySelectorAll('.copy-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            const url = this.dataset.url;
            navigator.clipboard.writeText(url).then(() => {
                const original = this.innerText;
                this.innerText = '✅';
                setTimeout(() => this.innerText = original, 2000);
            });
        });
    });
</script>
