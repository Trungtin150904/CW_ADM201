@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">

    <h1 class="display-5 fw-bold mb-3">URL Shortener Service</h1>
    <p class="lead text-muted mb-4">
        Shorten long links into short, memorable, and shareable links.<br />
        Trackate the number of clicks for each link.
    </p>

    <a asp-controller="ShortUrl" asp-action="Index"
           class="btn btn-primary btn-lg px-5 py-3 shadow">
        🚀 Start shortening URLs
    </a>

